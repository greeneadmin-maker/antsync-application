{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile with their anthill stats.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "totalFood": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "totalFood", "createdAt", "updatedAt"]
    },
    "task": {
      "title": "Task",
      "description": "A productivity task.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "timeSpent": { "type": "number" },
        "estimatedTime": { "type": "number" },
        "isCompleted": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "title", "timeSpent", "isCompleted", "createdAt", "updatedAt"]
    },
    "feedback": {
      "title": "Feedback",
      "description": "User feedback submission.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "rating": { "type": "number" },
        "useCase": { "type": "string" },
        "bestFeature": { "type": "string" },
        "painPoint": { "type": "string" },
        "zenModeFeedback": { "type": "string" },
        "themeFeedback": { "type": "string" },
        "desiredFeatures": { "type": "string" },
        "dailyUseFactor": { "type": "string" },
        "bugs": { "type": "string" },
        "additionalComments": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "rating", "useCase", "bestFeature", "painPoint", "zenModeFeedback", "themeFeedback", "desiredFeatures", "dailyUseFactor", "bugs", "additionalComments", "createdAt"]
    },
    "reward": {
      "title": "Reward",
      "description": "User claim for Canva subscription reward.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "canvaEmail": { "type": "string", "format": "email" },
        "feedbackId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "canvaEmail", "feedbackId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/user" },
      "description": "User profile documents"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/task" },
      "description": "Tasks created by users"
    },
    "/feedback/{feedbackId}": {
      "schema": { "$ref": "#/entities/feedback" },
      "description": "User feedback submissions"
    },
    "/rewards/{rewardId}": {
      "schema": { "$ref": "#/entities/reward" },
      "description": "Reward claims"
    }
  }
}
